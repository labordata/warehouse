# Data-less Datasette image for the *DuckDB* Fly.io deployment
# (app: warehouse-duckdb). Parallel to the SQLite image in `Dockerfile`.
#
# Same idea as the SQLite image — datasette + plugins + config only, no
# databases — but it installs the backend-abstraction branch of datasette
# plus the `datasette-duckdb` backend plugin (and the duckdb driver) instead
# of pysqlite3. The `.duckdb` files produced by `datasette_duckdb.convert`
# live on a Fly Volume mounted at /data and are uploaded out-of-band via
# `fly ssh sftp`, exactly like the SQLite track.
#
# NB: datasette + datasette-duckdb are installed from the `duckdb-backend`
# branch of the fgregg fork, which carries BOTH `datasette.backends` (the
# backend seams) and the plugin subdirectory. That branch must be pushed to
# github.com/fgregg/datasette for this build to succeed.

FROM python:3.12-slim

# git is needed because we pip install datasette + the plugin from
# git+https://... URLs (the SQLite image avoids git by using archive-zip URLs).
# wget is for pull-from-r2-direct.sh, which the refresh job SFTPs onto the
# machine and runs to populate /data from R2 (same script as the SQLite track,
# which gets wget via the main Dockerfile).
RUN apt-get update \
 && apt-get install -y --no-install-recommends build-essential git wget libgoogle-perftools4 \
 && rm -rf /var/lib/apt/lists/*
# ^ libgoogle-perftools4 (tcmalloc): TEMP, for native-heap leak profiling.
#   serve-duckdb.sh LD_PRELOADs libtcmalloc with HEAPPROFILE so pprof can show
#   the C++ allocation backtraces gc can't see (Debian jemalloc lacks prof).
#   Remove after diagnosis.

# datasette (backend seams) + the DuckDB backend plugin, both from
# `duckdb-deploy` — the merge of `duckdb-backend` (clean upstream PR
# candidate: backend abstraction + plugin) with `no_limit_csv` (the fork's
# extra fixes: uncapped `datasette inspect`, mode=ro immutable opens, no
# truncation on CSV stream, etc.). The plugin's
# `from datasette.backends import ...` resolves against a matching core.
#
# DATASETTE_REF is passed by the workflow as the commit SHA of duckdb-deploy
# (defaults to the branch name for local builds). Pinning to a SHA invalidates
# the Docker layer cache when datasette changes — without this, a `git+https`
# URL pointing at a branch is text-identical across deploys and BuildKit
# silently reuses the cached pip layer with stale code.
ARG DATASETTE_REF=duckdb-deploy
RUN pip install --no-cache-dir \
    "datasette @ git+https://github.com/fgregg/datasette@${DATASETTE_REF}" \
    "datasette-duckdb @ git+https://github.com/fgregg/datasette@${DATASETTE_REF}#subdirectory=datasette-duckdb" \
    "duckdb>=1.0" \
    datasette-atom==0.10a0 \
    datasette-block-robots \
    datasette-pretty-traces \
    https://github.com/fgregg/datasette-schema-org/archive/611e9b3dffaa7aed32f5a56cc250dd8f840f94d1.zip

# Bake the commit SHA into the rootfs so a deploy can verify the running
# container matches what was built (see deploy.yml's Verify step on the
# SQLite track). ARG passed by the workflow as GIT_SHA=$GITHUB_SHA.
ARG GIT_SHA=unknown
RUN echo "$GIT_SHA" > /etc/build-sha

WORKDIR /app

# Plugins and config — change with code, not data. We reuse the shared
# static/ and templates/, but a DuckDB-specific datasette config (the SQLite
# canned queries in datasette.yml use sqlite-only functions and would error).
COPY plugins/ /app/plugins/
COPY static/ /app/static/
COPY templates/ /app/templates/
COPY datasette.duckdb.yml /app/datasette.duckdb.yml
COPY warehouse_metadata.yml /app/
COPY scripts/ /app/scripts/
RUN chmod +x /app/scripts/*.sh

# .duckdb databases live on a Fly Volume mounted here.
VOLUME /data

EXPOSE 8080

CMD ["/app/scripts/serve-duckdb.sh"]
